<?xml version="1.0" encoding="UTF-8"?><document xmlns="http://www.ortodokskoptik.id/BukuBacaanKoptik">   <section expanded="true">         <Title data-section-header="true">         <language id="English">Litany of the Assemblies</language><language id="Indonesian">Litani Perkumpulan Jemaat</language>         <language id="Arabic">أوشية الاجتماعات</language>      </Title>            <insertdocument path="include/litanies/Assemblies.1" self-closing="true"> </insertdocument>                  <role id="Priest">         <group>            <season id="Baptism | Crowning | FuneralPrayer">               <insertdocument path="include/litanies/Assemblies.2" self-closing="true"> </insertdocument>            </season>                        <season id="Other">               <insertdocument path="include/AgainLetUsAsk" self-closing="true"> </insertdocument>                              <text>                  <language id="Coptic">                     Ten]ho ouoh tentwbh n~tekmeta~gayoc pimairwmi: a~riv~meui~ P[oic n~nenjinywou].                  </language>                              <language id="English">                     We ask and entreat Your goodness, O Lover of Mankind, remember, O Lord, our assemblies.                  </language><language id="Indonesian">                     Kami meminta dan memohon kebaikan-Mu, wahai Pengasih Umat Manusia, ingatlah, ya Tuhan, perkumpulan jemaat kami.</language>                  <language id="Arabic">                     نسألُ ونطلبُ من صلاحِك يا محبَّ البشرِ، اذكر ياربُّ اجتماعاتِنا.                  </language>               </text>            </season>         </group>                  <insertdocument path="include/litanies/Assemblies.3" self-closing="true"> </insertdocument>       </role>            <insertdocument path="include/litanies/Assemblies.4" self-closing="true"> </insertdocument>   </section></document>