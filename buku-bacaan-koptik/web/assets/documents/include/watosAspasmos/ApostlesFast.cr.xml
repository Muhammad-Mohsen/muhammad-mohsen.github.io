<?xml version="1.0" encoding="UTF-8"?><document xmlns="http://www.ortodokskoptik.id/BukuBacaanKoptik">   <season id="ApostlesFast">      <section>         <Title data-section-header="true">            <language id="English">Watos Aspasmos</language><language id="Indonesian">Watos Aspasmos</language>            <language id="Arabic">الاسبسمس الواطس</language>            <language id="Coptic">Nenio] eyouab...</language>         </Title>                  <comment>            <language id="English">               For the Fast of the Apostles:            </language><language id="Indonesian">               Untuk Puasa Para Rasul</language>         </comment>                        <text>            <language id="Coptic">               Nenio] eyouab n~a~poctoloc: n~yof eter[aumwit qajwou: sa n~toutacyo n~]oikoumen/: e~qoun e~p~couen ]meym/i.             </language>            <language id="English">               Our holy apostolic fathers the Apostles - He guided them, until they returned the world to the knowledge of the Truth.            </language><language id="Indonesian">               Dialah yang membimbing bapa kami para Rasul yang suci sampai mereka mengembalikan dunia kepada pengenalan akan Kebenaran.</language>            <language id="Arabic">               هو الذى أرشد أباءنا الرسل القديسين حتى ردوا المسكونة إلى معرفة الحق .            </language>                  </text>                                 <insertdocument path="include/watosAspasmos/SeasonalConclusion" self-closing="true"> </insertdocument>         <insertdocument path="include/watosAspasmos/Conclusion" self-closing="true"> </insertdocument>         </section>   </season></document>